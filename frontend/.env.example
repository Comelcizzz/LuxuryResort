# Дипломний фронт (Vite). Скопіюй у `.env` лише за потреби змінити дефолти.
#
# Базовий URL для Axios (за замовчуванням `/api` — dev-сервер проксує на Spring `http://localhost:8080`).
# VITE_API_BASE=http://localhost:8080/api
#
# Для продакшену без проксі вистав повний URL API, наприклад:
# VITE_API_BASE=https://api.example.com/api
